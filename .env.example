# ============================================================================
# Sentris — environment configuration
# Copy to `.env` and adjust. Every AI/threat-intel key below is OPTIONAL:
# the platform runs with zero paid keys using Ollama (local) and a mock
# threat-intel provider out of the box.
# ============================================================================

# --- Core app ---
ENVIRONMENT=development
APP_NAME=Sentris
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-prod-use-a-long-random-string
CORS_ORIGINS=http://localhost:3000

# --- Postgres ---
POSTGRES_USER=sentris_app
POSTGRES_PASSWORD=sentris_dev_password
POSTGRES_DB=sentris
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sentris_app:sentris_dev_password@db:5432/sentris

# Separate least-privilege migrator role (see docs/architecture.md).
# In dev this can be the same as the app user; in prod use a distinct role.
POSTGRES_MIGRATOR_USER=sentris_migrator
POSTGRES_MIGRATOR_PASSWORD=sentris_dev_migrator_password
DATABASE_MIGRATOR_URL=postgresql+psycopg://sentris_migrator:sentris_dev_migrator_password@db:5432/sentris

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT auth (Phase 4) ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# ============================================================================
# AI layer — free-first, provider-agnostic via LiteLLM (Phase 6)
# The router tries each configured provider in order and falls back on
# failure: NVIDIA NIM -> Groq -> OpenRouter (free) -> Ollama (local). Leave
# all cloud keys blank to run fully offline against local Ollama, or set one
# free key below. If nothing is reachable, AI endpoints degrade gracefully
# (clear "unavailable" response) — the rest of the app is unaffected.
# ============================================================================

# NVIDIA NIM — free tier at https://build.nvidia.com (no card required)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# Groq — free tier at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — free models at https://openrouter.ai (no card required)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Hugging Face Inference API — free tier (alternate provider)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Ollama — fully local, zero network, default for offline dev
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================================
# Threat intelligence — free tiers (Phase 5 enrichment + Phase 6.5 Investigate
# module). Each provider is opt-in per key — a missing key falls back to that
# one provider's built-in mock, so the platform (and the Investigate page)
# works fully with zero keys configured.
# ============================================================================
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Shodan — free tier at https://account.shodan.io/register (ip: ports/services/CVEs)
SHODAN_API_KEY=

# AlienVault OTX — free at https://otx.alienvault.com (all types: attribution/pulses)
OTX_API_KEY=

# GreyNoise Community — free at https://viz.greynoise.io/account/ (ip: scanner-vs-targeted)
GREYNOISE_API_KEY=

# abuse.ch (ThreatFox/MalwareBazaar) — free Auth-Key at https://auth.abuse.ch (hash/domain/url: malware family)
ABUSECH_API_KEY=

# urlscan.io — free at https://urlscan.io/user/signup (domain/url: screenshot + resources)
URLSCAN_API_KEY=

# WHOIS/RDAP needs no key — always available for domain age lookups.

THREAT_INTEL_USE_MOCK=true

# --- Notifications (Phase 7) ---
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
